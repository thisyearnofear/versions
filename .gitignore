# MODULAR: comprehensive .gitignore for the Lepton Submission
# Marketplace. Organized by category. The proxy is the only
# runtime; there is no Rust / Cargo / Vercel / Next.js in
# this repo. Anything that smells like those is dead.

# ---------- runtime / build artefacts ----------

# web client: hashed assets in web/dist/ are produced by
# `npm run build` and the Dockerfile's RUN layer; never
# checked in.
web/dist/

# tests: sqlite dbs from node:test's lifecycle
data/test-*.db
data/test-*.db-*

# runtime: sqlite dbs + uploads
data/versions.db
data/versions.db-*
data/uploads/

# node deps + lock-of-a-lock
node_modules/
package-lock.json.bak

# compiled output (defensive — we don't transpile)
*.js.map
*.d.ts
*.tsbuildinfo

# ---------- secrets + env ----------

.env
.env.local
.env.*.local
.env.production
config.js
secrets.js

# ---------- IDE / editor / OS ----------

# VS Code, JetBrains, Sublime
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# Mac / Windows OS metadata
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Personal CLI tool caches (leave the user's .junie/
# .qodo/ .blackboxcli/ on disk; never commit)
.junie/
.qodo/
.blackboxcli/

# ---------- patch artefacts (defensive) ----------

*.diff
*.orig
*.rej

# ---------- logs + temp ----------

*.log
*.log.*
logs/
tmp/
temp/

# ---------- benchmark / coverage (defensive) ----------

coverage/
.nyc_output/
*.lcov
bench/
*.bench
