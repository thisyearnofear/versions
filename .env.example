# Required: turbopuffer API key (get from https://turbopuffer.com)
TURBOPUFFER_API_KEY=tpuf_xxx

# Recommended: Hugging Face token for real semantic embeddings (free at https://huggingface.co/settings/tokens)
HF_API_TOKEN=hf_xxx

# Optional: ElevenLabs API key for audio generation
ELEVENLABS_API_KEY=

# Optional: turbopuffer namespace (default: versions-audio)
TURBOPUFFER_NAMESPACE=versions-audio

# Optional: limit tracks to ingest (default: 50)
INGEST_LIMIT=50
