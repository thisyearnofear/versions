# MODULAR: production env. Copy to .env.production, fill in
# the values, and `npm run deploy` reads from it. The
# proxy is mock-first; if ARC_RPC_URL is empty, the arc
# adapter runs in mock mode (the demo path). Same for
# LLM_API_KEY — empty = mock agent reviews.

# Required for any real settlement.
# Leave empty for the mock demo.
PLATFORM_WALLET=

# Required for real Arc.
# https://rpc.testnet.arc.network is the verified testnet
# (chain 5042002 / 0x4cef52, mock-friendly). ARC_USDC_CONTRACT
# is the Canteen-hosted testnet USDC contract — ask the Arc
# team in the Canteen Discord for the current address; it
# changes per round. PLATFORM_WALLET is a hot wallet you
# control that holds testnet USDC for paying out settlement
# legs. Get testnet USDC from the Arc faucet.
ARC_RPC_URL=
ARC_USDC_CONTRACT=

# Required for real LLM agent reviews.
# Leave empty for the mock demo (deterministic reviews).
# LLM_API_URL is any OpenAI-compatible chat completions endpoint.
# LLM_API_KEY is the bearer token for that endpoint.
# LLM_MODEL is the model name to request (default: gpt-4o-mini).
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Agent wallets. Leave empty for auto-generated deterministic wallets.
# Each agent (production, performance, market) gets its own wallet
# so settlement can pay them individually on publish.
AGENT_WALLET_1=
AGENT_WALLET_2=
AGENT_WALLET_3=

# A&R agent wallet. Receives listener payments and pays artists per play.
# Leave empty for auto-generated deterministic wallet.
AR_WALLET=

# Port the proxy listens on. Default 8080.
PORT=8080
HOST=0.0.0.0

# CORS allowed origins. Comma-separated. Default empty =
# same-origin only (the proxy serves the web client too,
# so a separate origin isn't typical).
ALLOWED_ORIGINS=

# Per-route request timeout in ms. Default 30000.
REQUEST_TIMEOUT_MS=30000

# Audio route rate limit (per IP, 60s window).
RATE_LIMIT_AUDIO_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Settlement sweeper.
SWEEPER_INTERVAL_MS=60000
SWEEPER_THRESHOLD_MS=30000

# Submission body cap (the JSON body of POST /submissions).
# Audio files sent via multipart/form-data use the same cap.
SUBMISSION_BODY_LIMIT=73400320

# Log level. One of: debug, info, warn, error.
LOG_LEVEL=info
