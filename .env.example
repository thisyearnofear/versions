# ── Database (required) ───────────────────────────────
# Neon serverless Postgres connection string.
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/versions

# ── Auth (required) ───────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=generate-a-random-32-char-string-here
NEXTAUTH_URL=http://localhost:3000

# ── Arc L1 settlement ─────────────────────────────────
# Omit both to run the Arc adapter in mock mode (deterministic hashes, no on-chain calls).
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_USDC_CONTRACT=0x3600000000000000000000000000000000000000
# Wallet that receives the platform share of each settlement leg.
PLATFORM_WALLET=

# ── LLM (AI curator agents) ───────────────────────────
# Omit LLM_API_KEY to run the LLM adapter in mock mode (deterministic reviews).
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── Agent + A&R wallets ───────────────────────────────
# Omit to use deterministic placeholder wallets (stable across restarts).
AGENT_WALLET_PRODUCTION=
AGENT_WALLET_PERFORMANCE=
AGENT_WALLET_MARKET=
AR_WALLET=

# ── IPFS / Pinata ─────────────────────────────────────
# Pinata JWT auth. Omit to skip IPFS pinning (uploads stay local only).
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Circle Gateway (x402 nanopayments) ────────────────
# Omit GATEWAY_API_URL to run the Gateway adapter in mock mode.
GATEWAY_API_URL=
GATEWAY_API_KEY=
GATEWAY_BATCH_INTERVAL_MS=500

# ── Client-side (NEXT_PUBLIC_*, inlined at build time) ─
# WalletConnect project ID — https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=
# Client-side Arc RPC fallback (defaults to ARC_RPC_URL server-side).
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
# Client-side submit receipt polling timeout (ms). Default 60000.
NEXT_PUBLIC_SUBMIT_RECEIPT_TIMEOUT_MS=60000

# ── Server tunables ───────────────────────────────────
# Submit receipt polling timeout for server-side workers (sweeper). Default 60000.
SUBMIT_RECEIPT_TIMEOUT_MS=60000
# Upload storage directory. Defaults to /tmp/uploads on Vercel, ./data/uploads locally.
UPLOAD_DIR=
# Rate limiter window + per-IP audio upload cap.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUDIO_MAX=30
# HTTP body / timeout / cache tunables.
JSON_BODY_LIMIT=256kb
UPSTREAM_TIMEOUT_MS=12000
SEMANTIC_CACHE_TTL_MS=30000
AUDIO_CACHE_TTL_MS=45000
# CORS — comma-separated origins, omit to allow same-origin only.
ALLOWED_ORIGINS=
# Log level: trace|debug|info|warn|error
LOG_LEVEL=info

# ── Upstash Redis (globally-coherent rate limiting) ────
# Omit both to use the in-memory rate limiter (per-instance, not
# globally coherent across serverless deployments).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── CLAP audio embeddings (semantic search) ────────────
# Omit EMBEDDING_API_URL to run the embedding adapter in mock mode
# (deterministic hash-based vectors; semantic search falls back to
# structured-tag-only scoring). Requires pgvector extension on the
# DB — run `npm run db:pgvector` to enable it.
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=clap-default
EMBEDDING_DIMENSIONS=512

# ── Monitoring (optional) ─────────────────────────────
SENTRY_DSN=
POSTHOG_KEY=
