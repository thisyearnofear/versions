# MODULAR: Netlify custom headers. Applied by Netlify to
# every static response. The same headers live in
# netlify.toml so a deploy to Vercel / Cloudflare / plain
# S3 + CloudFront works the same way.
#
# Reference: https://docs.netlify.com/routing/headers/

# MODULAR: security headers for every response.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# PERFORMANT: hashed assets in /dist/ get an immutable
# 1-year cache. The filename changes when the content
# changes, so the cache invalidation is implicit. Without
# this the browser revalidates every asset on every
# page load.
# MODULAR: netlify.toml also sets this header; the
# duplication is intentional — netlify.toml is the
# canonical config but _headers is the portable fallback.
/dist/*
  Cache-Control: public, max-age=31536000, immutable

# MODULAR: the index.html stays no-cache so deploys are
# picked up immediately. (The hashed assets are immutable
# but the index references them by their hashed names, so
# a stale index would mean a stale reference to a stale
# asset — the no-cache here keeps the entry HTML fresh.)
/index.html
  Cache-Control: no-cache
