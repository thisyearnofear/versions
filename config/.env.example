# API Keys - Copy this to .env and add your keys
AUDIUS_API_KEY=your_audius_api_key_here
AUDIUS_API_SECRET=your_audius_api_secret_here
HELIUS_API_KEY=your_helius_api_key_here

# Blockchain RPC URLs
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# IPFS Configuration
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
IPFS_API_URL=http://localhost:5001

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# Frontend Configuration (for production deployment)
FRONTEND_URL=https://versions.thisyearnofear.com

# Farcaster Mini App Configuration (optional - only needed if deploying Farcaster integration)
FARCASTER_APP_NAME=VERSIONS
FARCASTER_DOMAIN=versions.thisyearnofear.com
FARCASTER_ICON_URL=https://versions.thisyearnofear.com/app.png
FARCASTER_HOME_URL=https://versions.thisyearnofear.com/
FARCASTER_IMAGE_URL=https://versions.thisyearnofear.com/opengraph-image.png
FARCASTER_BUTTON_TITLE=Open
FARCASTER_SPLASH_IMAGE_URL=https://versions.thisyearnofear.com/app.png
FARCASTER_SPLASH_BG=#000000
